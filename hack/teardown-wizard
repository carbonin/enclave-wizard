#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ]; then
    echo "Usage: $0 <user@host>"
    echo "Example: $0 root@myserver.example.com"
    exit 1
fi

TARGET="$1"
VM_NAME="enclave-wizard-lz"
HTTP_PORT=3001
HTTPS_PORT=3443

echo "=== Tearing down Enclave Wizard on ${TARGET} ==="

ssh -o StrictHostKeyChecking=no "${TARGET}" "
    # Get VM IP before destroying for iptables cleanup
    VM_IP=\$(virsh domifaddr ${VM_NAME} 2>/dev/null | grep -oP '(\d+\.){3}\d+' | head -1) || true

    # Destroy VM
    virsh destroy ${VM_NAME} 2>/dev/null || true
    virsh undefine ${VM_NAME} --remove-all-storage 2>/dev/null || true

    # Clean up port forwarding
    if [ -n \"\${VM_IP:-}\" ]; then
        for PORT in ${HTTP_PORT} ${HTTPS_PORT}; do
            iptables -t nat -D PREROUTING -p tcp --dport \${PORT} -j DNAT --to-destination \${VM_IP}:\${PORT} 2>/dev/null || true
            iptables -D FORWARD -p tcp -d \${VM_IP} --dport \${PORT} -j ACCEPT 2>/dev/null || true
        done
    fi

    # Clean up firewall
    firewall-cmd --remove-port=${HTTP_PORT}/tcp --permanent 2>/dev/null || true
    firewall-cmd --remove-port=${HTTPS_PORT}/tcp --permanent 2>/dev/null || true
    firewall-cmd --reload 2>/dev/null || true

    # Clean up temp files
    rm -f /tmp/enclave-wizard.rpm
"

echo "Done."
