#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ]; then
    echo "Usage: $0 <user@host>"
    echo "Example: $0 root@myserver.example.com"
    exit 1
fi

TARGET="$1"
VM_NAME="enclave-wizard-lz"
HTTP_PORT=3001
HTTPS_PORT=3443

echo "=== Tearing down Enclave Wizard on ${TARGET} ==="

ssh -o StrictHostKeyChecking=no "${TARGET}" "
    # Kill port forwarders
    pkill -f 'socat.*TCP-LISTEN:3001' 2>/dev/null || true
    pkill -f 'socat.*TCP-LISTEN:3443' 2>/dev/null || true

    # Destroy VM
    virsh destroy ${VM_NAME} 2>/dev/null || true
    virsh undefine ${VM_NAME} --remove-all-storage --nvram 2>/dev/null || true

    # Clean up firewall
    firewall-cmd --remove-port=${HTTP_PORT}/tcp --permanent 2>/dev/null || true
    firewall-cmd --remove-port=${HTTPS_PORT}/tcp --permanent 2>/dev/null || true
    firewall-cmd --reload 2>/dev/null || true

    # Clean up temp files
    rm -f /tmp/enclave-wizard.rpm /tmp/enclave-wizard-tunnel
"

echo "Done."
