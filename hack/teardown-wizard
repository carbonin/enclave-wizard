#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ]; then
    echo "Usage: $0 <user@host>"
    echo "Example: $0 root@myserver.example.com"
    exit 1
fi

TARGET="$1"
VM_NAME="enclave-wizard-lz"
WIZARD_PORT=3001

echo "=== Tearing down Enclave Wizard on ${TARGET} ==="

ssh -o StrictHostKeyChecking=no "${TARGET}" "
    # Get VM IP before destroying for iptables cleanup
    VM_IP=\$(virsh domifaddr ${VM_NAME} 2>/dev/null | grep -oP '(\d+\.){3}\d+' | head -1) || true

    # Destroy VM
    virsh destroy ${VM_NAME} 2>/dev/null || true
    virsh undefine ${VM_NAME} --remove-all-storage 2>/dev/null || true

    # Clean up port forwarding
    if [ -n \"\${VM_IP:-}\" ]; then
        iptables -t nat -D PREROUTING -p tcp --dport ${WIZARD_PORT} -j DNAT --to-destination \${VM_IP}:${WIZARD_PORT} 2>/dev/null || true
        iptables -D FORWARD -p tcp -d \${VM_IP} --dport ${WIZARD_PORT} -j ACCEPT 2>/dev/null || true
    fi

    # Clean up firewall
    firewall-cmd --remove-port=${WIZARD_PORT}/tcp --permanent 2>/dev/null || true
    firewall-cmd --reload 2>/dev/null || true

    # Clean up temp files
    rm -f /tmp/enclave-wizard /tmp/enclave-wizard-ui.tar /tmp/provision.sh /tmp/nginx-deploy.conf
    rm -rf /tmp/quadlets
"

echo "Done."
